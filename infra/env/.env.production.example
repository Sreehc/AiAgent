APP_PORT=18080
APP_JWT_SECRET=replace-with-a-long-random-secret
APP_SESSION_TTL_SECONDS=7200
APP_LOGIN_FAILURE_LIMIT=5
APP_LOGIN_FAILURE_WINDOW_SECONDS=600
APP_SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-secret

APP_DB_HOST=host.docker.internal
APP_DB_PORT=5432
APP_DB_NAME=aiagent
APP_DB_USERNAME=aiagent
APP_DB_PASSWORD=change-me

APP_REDIS_HOST=host.docker.internal
APP_REDIS_PORT=6379

APP_KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092
APP_KAFKA_KNOWLEDGE_INDEX_TOPIC=aiagent.knowledge.index
APP_KAFKA_CONSUMER_GROUP=aiagent-backend

APP_MINIO_ENDPOINT=http://host.docker.internal:9000
APP_MINIO_ACCESS_KEY=change-me
APP_MINIO_SECRET_KEY=change-me
APP_MINIO_BUCKET=aiagent
APP_STORAGE_PRESIGNED_URL_TTL_SECONDS=900

APP_EMBEDDING_PROVIDER=local-mock
APP_EMBEDDING_MODEL_CODE=text-embedding-3-small
APP_EMBEDDING_BASE_URL=
APP_EMBEDDING_API_KEY=
APP_EMBEDDING_DIMENSION=1536
APP_EMBEDDING_CONNECT_TIMEOUT_MILLIS=5000
APP_EMBEDDING_READ_TIMEOUT_MILLIS=15000

APP_RAG_EMBEDDING_CACHE_TTL_SECONDS=3600
APP_RAG_RETRIEVAL_CACHE_TTL_SECONDS=300
APP_RAG_RETRIEVAL_TIMEOUT_MILLIS=1500

APP_CHAT_PROVIDER=local-mock
APP_CHAT_MODEL_CODE=local-chat
APP_CHAT_BASE_URL=
APP_CHAT_API_KEY=

APP_IMAGE_PROVIDER=local-mock
APP_IMAGE_MODEL_CODE=local-image
APP_IMAGE_BASE_URL=
APP_IMAGE_API_KEY=

APP_MCP_ALLOWED_HOSTS=localhost
APP_MCP_ALLOW_PRIVATE_NETWORK=true
APP_MCP_ALLOWED_STDIO_EXECUTABLES=
APP_BOOTSTRAP_DEMO_DATA_ENABLED=false
